# Mr. Kek — required environment variables (authoritative key list / Doppler config schema, D-08).
# Copy to .env for the plain-.env fallback, or load these via `doppler run -- <cmd>`.
# PLACEHOLDER VALUES ONLY — never commit a real secret, token, session string, or chat id.

# Bot API token from @BotFather
BOT_TOKEN=000000000:replace-with-bot-token

# MTProto App credentials from my.telegram.org
API_ID=000000
API_HASH=replace-with-api-hash

# MTProto StringSession — generate a fresh one with `npm run login` (rotate the leaked key, SPEC §3)
SESSION_KEY=replace-with-string-session

# Main group chat id (large negative supergroup id, e.g. -100XXXXXXXXXX)
MAIN_CHAT_ID=-100XXXXXXXXXX

# Casino relay channel id (large negative channel id, e.g. -100XXXXXXXXXX)
RELAY_CHANNEL_ID=-100XXXXXXXXXX
